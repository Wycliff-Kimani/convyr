# ============================================================
# Convyr — Backend Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to Git.
# ============================================================


# ========================
# App Settings
# ========================
APP_NAME=Convyr
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=true
PORT=8000


# ========================
# WhatsApp / Meta Cloud API
# ========================
# Your permanent access token from Meta Developer Portal
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here

# From Meta Developer Portal > WhatsApp > Getting Started
WHATSAPP_PHONE_NUMBER_ID=1089779964214051
WHATSAPP_BUSINESS_ACCOUNT_ID=1468101211513331

# Any secret string you choose — must match exactly what you
# register in Meta Developer Portal > Webhooks > Verify Token
WHATSAPP_VERIFY_TOKEN=convyr-webhook-secret-change-me


# ========================
# Supabase (PostgreSQL)
# ========================
# Create a free Supabase project at https://supabase.com
# Then go to: Project Settings > API to find these values.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Go to: Project Settings > Database > Connection String (URI mode)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres


# ========================
# Upstash Redis
# ========================
# Create a free Redis database at https://upstash.com
# Then go to: Database Details > REST API

REDIS_URL=rediss://default:your-redis-token@your-upstash-endpoint.upstash.io:6379
REDIS_TOKEN=your-upstash-redis-token-here


# ========================
# PayHero (M-Pesa Payments)
# ========================
# Sign up at https://app.payhero.co.ke
# Go to: Settings > API Keys to find your credentials.
# Channel ID is found under: Payment Channels > Your Channel

PAYHERO_USERNAME=your-payhero-api-username
PAYHERO_PASSWORD=your-payhero-api-password
PAYHERO_CHANNEL_ID=your-payhero-channel-id
PAYHERO_API_URL=https://backend.payhero.co.ke/api/v2

# Public URL where PayHero will send payment confirmation callbacks.
# In development use ngrok: https://your-ngrok-url.ngrok.io/api/v1/payments/callback
PAYHERO_CALLBACK_URL=https://your-domain.com/api/v1/payments/callback


# ========================
# CORS — Allowed Frontend Origins
# ========================
# Comma-separated list, no trailing slash
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
